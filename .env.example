# Copy this file to .env for local experiments. Do not commit .env.

# Project paths
MAD_BASE_DIR=/content/mad_identity_verification
APP_STORAGE_DIR=/content/mad_identity_verification/storage
APP_ARTIFACTS_DIR=/content/mad_identity_verification/artifacts

# Supabase demo settings. Use anon public key only, never service-role key.
SUPABASE_URL=
SUPABASE_KEY=

# OCR runtime
OCR_DEVICE=cpu
OCR_WORKER_TIMEOUT_SEC=900
OCR_QUALITY_PRESETS=0
OCR_FAST_MODE=1
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
PADDLE_DET_LIMIT_TYPE=max
PADDLE_DET_LIMIT_SIDE_LEN=1600
PADDLE_TEXTLINE_ORIENTATION=false
PADDLE_USE_DOC_UNWARPING=false
PADDLE_DET_MODEL=PP-OCRv5_mobile_det
PADDLE_REC_MODEL=cyrillic_PP-OCRv5_mobile_rec

# Face verification
FACE_MODEL_NAME=Facenet512
FACE_DETECTOR_BACKEND=retinaface
FACE_ACCEPT_THRESHOLD=0.32
FACE_REVIEW_THRESHOLD=0.43

# Passport data matching
DATA_ACCEPT_THRESHOLD=0.80
DATA_REVIEW_THRESHOLD=0.55

# DeepFace / TensorFlow compatibility
TF_USE_LEGACY_KERAS=1

# Security/privacy toggles
MAX_UPLOAD_MB=20
STORE_DEBUG_ARTIFACTS=0
GRADIO_DEBUG=0
# Set to 1 only in a disposable Colab runtime if you want the app to try pip repair installs automatically.
MAD_AUTO_INSTALL_DEEPFACE=0
